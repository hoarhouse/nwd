---
layout: base.njk
title: Writing
summary: Essays and reflections from the Domus Communis Foundation.
bodyClass: writing
---
<div class="section-head">
  <h1>Writing</h1>
  <p class="section-dek">Essays and reflections on technology, conscience, and the human person.</p>
</div>
{% for essay in collections.essays | reverse %}
  {% if loop.first %}
  <a class="wx-feature" href="{{ essay.url }}">
    {% if essay.data.hero %}<div class="wx-feature-thumb"><img src="{{ essay.data.hero }}" alt=""></div>{% else %}<div class="wx-feature-thumb wx-typethumb">{% if essay.data.category %}<span class="wx-type-label">{{ essay.data.category }}</span>{% endif %}<span class="wx-type-title">{{ essay.data.title }}</span></div>{% endif %}
    <div class="wx-feature-text">
      {% if essay.data.category %}<p class="wx-kicker">{{ essay.data.category }}</p>{% endif %}
      <h2 class="wx-feature-title">{{ essay.data.title }}</h2>
      {% if essay.data.summary %}<p class="wx-feature-dek">{{ essay.data.summary }}</p>{% endif %}
      {% if essay.data.date %}<p class="wx-meta"><time datetime="{{ essay.data.date | isoDate }}">{{ essay.data.date | dateDisplay }}</time></p>{% endif %}
    </div>
  </a>
  <ul class="wx-grid">
  {% endif %}
  {% if not loop.first %}
    <li class="wx-card{% if not essay.data.hero %} wx-card-dark{% endif %}">
      <a class="wx-card-link" href="{{ essay.url }}">
        {% if essay.data.hero %}
        <div class="wx-thumb"><img src="{{ essay.data.hero }}" alt=""></div>
        <div class="wx-text">
          {% if essay.data.category %}<p class="wx-kicker">{{ essay.data.category }}</p>{% endif %}
          <h2 class="wx-title">{{ essay.data.title }}</h2>
          {% if essay.data.summary %}<p class="wx-dek">{{ essay.data.summary }}</p>{% endif %}
          {% if essay.data.date %}<p class="wx-meta"><time datetime="{{ essay.data.date | isoDate }}">{{ essay.data.date | dateDisplay }}</time></p>{% endif %}
        </div>
        {% else %}
        <div class="wx-thumb wx-typethumb">{% if essay.data.category %}<span class="wx-type-label">{{ essay.data.category }}</span>{% endif %}<span class="wx-type-title">{{ essay.data.title }}</span></div>
        <div class="wx-text">
          {% if essay.data.summary %}<p class="wx-dek">{{ essay.data.summary }}</p>{% endif %}
          {% if essay.data.date %}<p class="wx-meta"><time datetime="{{ essay.data.date | isoDate }}">{{ essay.data.date | dateDisplay }}</time></p>{% endif %}
        </div>
        {% endif %}
      </a>
    </li>
  {% endif %}
  {% if loop.last %}</ul>{% endif %}
{% endfor %}
