<script>
  document.querySelectorAll('.btn-view, .library-thumb-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.library-item');
      var viewer = item.querySelector('.library-viewer');
      var open = btn.getAttribute('aria-expanded') === 'true';
      if (open) {
        viewer.hidden = true;
        viewer.innerHTML = '';
        btn.setAttribute('aria-expanded', 'false');
        btn.textContent = 'View slides';
      } else {
        viewer.innerHTML = '<iframe class="library-frame" src="' + btn.dataset.pdf + '" title="' + item.querySelector('.library-title').textContent + '" loading="lazy"></iframe>';
        viewer.hidden = false;
        btn.setAttribute('aria-expanded', 'true');
        btn.textContent = 'Hide slides';
      }
    });
  });
</script>
