---
layout: base.njk
title: Library
summary: "Presentations and resources from the Domus Communis Foundation on data sovereignty, sovereign AI, and values-based technology."
bodyClass: article
---
<article class="library-page">
  <header class="essay-banner essay-banner-plain lib-banner">
    <div class="essay-banner-inner">
      <p class="essay-kicker"><span class="essay-publication">Resources</span></p>
      <h1 class="essay-title">Library</h1>
      <p class="essay-dek">Presentations from the Domus Communis Foundation on data sovereignty, sovereign AI, and values-based technology — grounded in Catholic Social Teaching.</p>
    </div>
  </header>

  <div class="lib-wrap">
    <ul class="library-list">

      <li class="library-item">
        <h2 class="library-title">Value-Based AI and Catholic Teaching</h2>
        <p class="library-dek">How Catholic moral principles can shape the design and deployment of artificial intelligence.</p>
        <button class="library-thumb-btn" type="button" data-pdf="/assets/library/value-based-ai-catholic-teaching.pdf"><img class="library-thumb" src="/assets/library/value-based-ai-catholic-teaching-thumb.png" alt="First slide preview"></button>
        <div class="library-actions">
          <button class="btn-view" type="button" data-pdf="/assets/library/value-based-ai-catholic-teaching.pdf" aria-expanded="false">View slides</button>
          <a class="btn-dl" href="/assets/library/value-based-ai-catholic-teaching.pdf" download>Download PDF</a>
          <a class="btn-dl" href="/assets/library/value-based-ai-catholic-teaching.pptx" download>Download PowerPoint</a>
        </div>
        <div class="library-viewer" hidden></div>
      </li>

      <li class="library-item">
        <h2 class="library-title">Sovereign Data, AI, and Catholic Social Teaching</h2>
        <p class="library-dek">Connecting data sovereignty and sovereign AI to the Church's social tradition.</p>
        <button class="library-thumb-btn" type="button" data-pdf="/assets/library/sovereign-data-ai-catholic-social-teaching.pdf"><img class="library-thumb" src="/assets/library/sovereign-data-ai-catholic-social-teaching-thumb.png" alt="First slide preview"></button>
        <div class="library-actions">
          <button class="btn-view" type="button" data-pdf="/assets/library/sovereign-data-ai-catholic-social-teaching.pdf" aria-expanded="false">View slides</button>
          <a class="btn-dl" href="/assets/library/sovereign-data-ai-catholic-social-teaching.pdf" download>Download PDF</a>
          <a class="btn-dl" href="/assets/library/sovereign-data-ai-catholic-social-teaching.pptx" download>Download PowerPoint</a>
        </div>
        <div class="library-viewer" hidden></div>
      </li>

      <li class="library-item">
        <h2 class="library-title">Valuing Sovereign Data</h2>
        <p class="library-dek">Why individual and collective data ownership matters in the AI economy.</p>
        <button class="library-thumb-btn" type="button" data-pdf="/assets/library/valuing-sovereign-data.pdf"><img class="library-thumb" src="/assets/library/valuing-sovereign-data-thumb.png" alt="First slide preview"></button>
        <div class="library-actions">
          <button class="btn-view" type="button" data-pdf="/assets/library/valuing-sovereign-data.pdf" aria-expanded="false">View slides</button>
          <a class="btn-dl" href="/assets/library/valuing-sovereign-data.pdf" download>Download PDF</a>
          <a class="btn-dl" href="/assets/library/valuing-sovereign-data.pptx" download>Download PowerPoint</a>
        </div>
        <div class="library-viewer" hidden></div>
      </li>

    </ul>
  </div>

  <script>
(function(){
  function svg(inner, fill){ return '<svg viewBox="0 0 24 24" fill="'+(fill||'none')+'" stroke="'+(fill?'none':'currentColor')+'" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">'+inner+'</svg>'; }
  var ICON = {
    share:'<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/>',
    link:'<path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.72"/><path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.72-1.72"/>',
    mail:'<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
    li:'<path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3-.02-2.97-1.8-2.97-1.82 0-2.1 1.4-2.1 2.87V21h-4z"/>',
    fb:'<path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/>',
    x:'<path d="M18.24 2H21.5l-7.5 8.57L23 22h-6.94l-5.43-7.1L4.4 22H1.13l8.02-9.17L1 2h7.12l4.9 6.48L18.24 2z"/>'
  };
  function shareRow(url, title){
    var u=encodeURIComponent(url), t=encodeURIComponent(title);
    return '<div class="lib-share">'
      + '<span class="lib-share-label">Share</span>'
      + '<button class="psh-btn psh-primary lib-native" type="button" aria-label="Share" hidden>'+svg(ICON.share)+'</button>'
      + '<button class="psh-btn lib-copy" type="button">'+svg(ICON.link)+'<span class="lib-copy-lbl">Link</span></button>'
      + '<a class="psh-btn" rel="noopener" href="mailto:?subject='+t+'&body='+t+'%0A%0A'+u+'">'+svg(ICON.mail)+'<span class="lbl">Email</span></a>'
      + '<a class="psh-btn" target="_blank" rel="noopener" aria-label="Share on LinkedIn" href="https://www.linkedin.com/sharing/share-offsite/?url='+u+'">'+svg(ICON.li,'currentColor')+'<span class="lbl">LinkedIn</span></a>'
      + '<a class="psh-btn" target="_blank" rel="noopener" aria-label="Share on Facebook" href="https://www.facebook.com/sharer/sharer.php?u='+u+'">'+svg(ICON.fb,'currentColor')+'<span class="lbl">Facebook</span></a>'
      + '<a class="psh-btn" target="_blank" rel="noopener" aria-label="Share on X" href="https://twitter.com/intent/tweet?url='+u+'&text='+t+'">'+svg(ICON.x,'currentColor')+'<span class="lbl">X</span></a>'
      + '</div>';
  }
  function wireShare(viewer, url){
    var nb=viewer.querySelector('.lib-native');
    if(navigator.share){ nb.hidden=false; nb.addEventListener('click',function(){ navigator.share({url:url}).catch(function(){}); }); }
    var copy=viewer.querySelector('.lib-copy'), lbl=viewer.querySelector('.lib-copy-lbl');
    function done(){ copy.classList.add('psh-copied'); lbl.textContent='Copied!'; setTimeout(function(){ copy.classList.remove('psh-copied'); lbl.textContent='Link'; },1600); }
    function fb(){ var ta=document.createElement('textarea'); ta.value=url; ta.style.position='absolute'; ta.style.left='-9999px'; document.body.appendChild(ta); ta.select(); try{document.execCommand('copy');}catch(e){} document.body.removeChild(ta); done(); }
    copy.addEventListener('click',function(){ if(navigator.clipboard&&navigator.clipboard.writeText){ navigator.clipboard.writeText(url).then(done).catch(fb); } else { fb(); } });
  }
  document.querySelectorAll('.btn-view, .library-thumb-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.library-item');
      var viewer = item.querySelector('.library-viewer');
      var open = btn.getAttribute('aria-expanded') === 'true';
      if (open) {
        viewer.hidden = true; viewer.innerHTML = '';
        var tc = item.querySelector('.library-thumb-btn'); if (tc) { tc.hidden = false; }
        btn.setAttribute('aria-expanded', 'false');
        if (btn.classList.contains('btn-view')) { btn.textContent = 'View slides'; }
      } else {
        var pdfUrl = location.origin + btn.dataset.pdf;
        var title = item.querySelector('.library-title').textContent;
        viewer.innerHTML = shareRow(pdfUrl, title) + '<iframe class="library-frame" src="' + btn.dataset.pdf + '" title="' + title + '" loading="lazy"></iframe>';
        wireShare(viewer, pdfUrl);
        viewer.hidden = false;
        var to = item.querySelector('.library-thumb-btn'); if (to) { to.hidden = true; }
        btn.setAttribute('aria-expanded', 'true');
        if (btn.classList.contains('btn-view')) { btn.textContent = 'Hide slides'; }
      }
    });
  });
})();
</script>
</article>
