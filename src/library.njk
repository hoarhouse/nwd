    <button class="library-thumb-btn" type="button" data-pdf="/assets/library/sovereign-data-ai-catholic-social-teaching.pdf"><img class="library-thumb" src="/assets/library/sovereign-data-ai-catholic-social-teaching-thumb.png" alt="First slide preview" loading="lazy"></button>
