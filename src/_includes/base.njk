<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — DCF Foundation{% else %}DCF Foundation{% endif %}</title>
  {% if summary %}<meta name="description" content="{{ summary }}">{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Manrope:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap">
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body class="{% if bodyClass %}{{ bodyClass }}{% endif %}">
  <header class="site-header">
    <a class="site-brand" href="/">Domus Communis</a>
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <nav class="site-nav" id="site-nav" aria-label="Primary">
      <a class="nav-home" href="/">Home</a>
      <a href="/writing/">Writing</a>
      <a href="/newsroom/">Newsroom</a>
      <a href="/about/">About</a>
      <a href="/events/">Events</a>
      <a href="/initiatives/">Initiatives</a>
      <a href="/library/">Library</a>
      <a href="/get-involved/">Get Involved</a>
      <a class="nav-donate" href="/donate/">Donate</a>
    </nav>
  </header>
  <div class="nav-overlay" hidden></div>
  <main>
    {{ content | safe }}
  </main>
  <footer class="site-footer">
    <p class="footer-org">Domus Communis Foundation</p>
    <p class="footer-legal">A registered 501(c)(3) non-profit organization. Donations are tax-deductible to the fullest extent allowed by law. EIN: 99-1778616.</p>
    <p class="footer-tagline">Inspired by Catholic Social Teaching. Serving people of all faiths and values.</p>
    <p class="footer-links"><a href="/contact/">Contact</a> · <a href="/privacy/">Privacy</a></p>
  </footer>
  <script src="/assets/js/carousel.js" defer></script>
  <script src="/assets/js/nav.js" defer></script>
  <script>
    (function(){
      var h=document.querySelector('.site-header');
      if(h){ var onScroll=function(){ h.classList.toggle('scrolled', window.scrollY>60); }; onScroll(); addEventListener('scroll', onScroll, {passive:true}); }
      var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)e.target.classList.add('in');});},{threshold:0.15});
      document.querySelectorAll('.cine-reveal').forEach(function(el){io.observe(el);});
    })();
  </script>
</body>
</html>
