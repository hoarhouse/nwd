<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — DCF Foundation{% else %}DCF Foundation{% endif %}</title>
  {% if summary %}<meta name="description" content="{{ summary }}">{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Manrope:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap">
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body class="{% if bodyClass %}{{ bodyClass }}{% endif %}">
  <header class="site-header">
    <a class="site-brand" href="/">Domus Communis</a>
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <nav class="site-nav" id="site-nav" aria-label="Primary">
      <a class="nav-home" href="/">Home</a>
      <a href="/writing/">Writing</a>
      <a href="/newsroom/">Newsroom</a>
      <a href="/about/">About</a>
      <a href="/events/">Events</a>
      <a href="/initiatives/">Initiatives</a>
      <a href="/library/">Library</a>
      <a href="/get-involved/">Get Involved</a>
      <a class="nav-donate" href="/donate/">Donate</a>
    </nav>
  </header>
  <div class="nav-overlay" hidden></div>
  <main>
    {{ content | safe }}
  </main>
  <footer class="site-footer">
    <div class="footer-main">

      <div class="footer-brand">
        <p class="footer-org">Domus Communis Foundation</p>
        <p class="footer-tagline">A global, Catholic-inspired foundation working to ensure AI and emerging technology serve human dignity and the common good.</p>
        <div class="footer-socials">
          <a href="{{ social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
          <a href="{{ social.linkedin }}" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3-.02-2.97-1.8-2.97-1.82 0-2.1 1.4-2.1 2.87V21h-4z"/></svg></a>
          <a href="{{ social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg></a>
          <a href="{{ social.x }}" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.24 2H21.5l-7.5 8.57L23 22h-6.94l-5.43-7.1L4.4 22H1.13l8.02-9.17L1 2h7.12l4.9 6.48L18.24 2z"/></svg></a>
          <a href="{{ social.youtube }}" target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.5c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor" stroke="none"/></svg></a>
          <a href="{{ social.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M16.6 5.82A4.28 4.28 0 0 1 15.54 3h-3.09v12.4a2.59 2.59 0 1 1-2.59-2.59c.27 0 .53.04.78.12V9.4a5.96 5.96 0 0 0-.78-.05 5.69 5.69 0 1 0 5.69 5.69V8.83a7.35 7.35 0 0 0 4.25 1.36V7.1a4.28 4.28 0 0 1-3.2-1.28z"/></svg></a>
        </div>
      </div>

      <div class="footer-col">
        <h4>Explore</h4>
        <ul>
          <li><a href="/writing/">Writing</a></li>
          <li><a href="/newsroom/">Newsroom</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/events/">Events</a></li>
          <li><a href="/initiatives/">Initiatives</a></li>
          <li><a href="/library/">Library</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Get Involved</h4>
        <ul>
          <li><a href="/get-involved/">Get Involved</a></li>
          <li><a href="/donate/">Donate</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="/get-involved/">Partner With Us</a></li>
        </ul>
      </div>

      <div class="footer-news">
        <h4>Stay Informed</h4>
        <p>Updates on our initiatives, events, and writing &mdash; occasionally, never spam.</p>
        <form class="footer-news-form" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="newsletter">
          <p style="display:none"><label>Don't fill this out: <input name="bot-field"></label></p>
          <input type="email" name="email" placeholder="you@example.com" aria-label="Email address" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>

    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <div class="footer-legal-block">
          A registered 501(c)(3) non-profit organization. Donations are tax-deductible to the fullest extent allowed by law. EIN: 99-1778616.
          <span class="footer-tag2">Inspired by Catholic Social Teaching. Serving people of all faiths and values.</span>
        </div>
        <div class="footer-bottom-links">
          <a href="/contact/">Contact</a>
          <a href="/privacy/">Privacy</a>
          <span>&copy; 2026 Domus Communis Foundation</span>
        </div>
      </div>
    </div>
  </footer>
  <script src="/assets/js/carousel.js" defer></script>
  <script src="/assets/js/nav.js" defer></script>
  <script>
    (function(){
      var h=document.querySelector('.site-header');
      if(h){ var onScroll=function(){ h.classList.toggle('scrolled', window.scrollY>60); }; onScroll(); addEventListener('scroll', onScroll, {passive:true}); }
      var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)e.target.classList.add('in');});},{threshold:0.15});
      document.querySelectorAll('.cine-reveal').forEach(function(el){io.observe(el);});
    })();
  </script>
</body>
</html>
