<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — DCF Foundation</title>
  {% if summary %}<meta name="description" content="{{ summary }}">{% endif %}
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: #1A1A1A; background: #FAFAF7; max-width: 720px; margin: 0 auto; padding: 2rem 1.25rem; line-height: 1.6; }
    header { padding-bottom: 1.5rem; border-bottom: 1px solid #e5e5e0; margin-bottom: 2rem; }
    header a { color: #1A1A1A; text-decoration: none; font-weight: 600; font-size: 1.1rem; }
    footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #e5e5e0; color: #666; font-size: 0.85rem; }
  </style>
</head>
<body>
  <header>
    <a href="/">DCF Foundation</a>
  </header>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    <p>Domus Communis Foundation</p>
  </footer>
</body>
</html>