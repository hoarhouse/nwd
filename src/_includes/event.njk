---
layout: base.njk
bodyClass: article
---
<article class="event">
  <header class="essay-banner event-banner{% if not cardImage %} essay-banner-plain{% endif %}">
    {% if cardImage %}<div class="essay-banner-bg"><img src="{{ cardImage }}" alt="{{ title }}"></div>{% endif %}
    <div class="essay-banner-inner">
      {% if series %}<p class="essay-kicker"><span class="essay-publication">{{ series }}</span></p>{% endif %}
      <h1 class="essay-title">{{ title }}</h1>
      {% if subtitle %}<p class="essay-dek">{{ subtitle }}</p>{% endif %}
      {% if partner %}<p class="event-banner-partner">{{ partner }}</p>{% endif %}
      <p class="event-banner-meta">
        <time datetime="{{ date | isoDate }}">{{ date | dateDisplay }}</time>{% if eventTime %} · {{ eventTime }}{% endif %}{% if location %} · {% if locationUrl %}<a href="{{ locationUrl }}">{{ location }}</a>{% else %}{{ location }}{% endif %}{% endif %}
      </p>
      {% if registrationUrl and not (date | isPast) %}<p class="event-banner-cta"><a class="cine-btn-solid" href="{{ registrationUrl }}">Register</a></p>{% endif %}
      {% if date | isPast %}<p class="event-banner-status">{% if registrationUrl %}Registration for this event is closed.{% else %}This event has taken place — a recap follows below.{% endif %}</p>{% endif %}
    </div>
  </header>
  <div class="event-body">
    {{ content | safe }}
  </div>
  {% if speakers and speakers.length > 0 %}
  <section class="event-speakers">
    <h2 class="event-speakers-heading">Featured Contributions</h2>
    {% for speaker in speakers %}
    <div class="speaker">
      <div class="speaker-head">
        {% if speaker.headshot %}<img class="avatar" src="{{ speaker.headshot }}" alt="{{ speaker.name }}">{% elif speaker.initials %}<span class="avatar avatar-initials" aria-hidden="true">{{ speaker.initials }}</span>{% endif %}
        <div class="speaker-head-text">
          <h3 class="speaker-name">{{ speaker.name }}</h3>
          {% if speaker.talk %}<p class="speaker-talk">{{ speaker.talk }}</p>{% endif %}
          {% if speaker.bio %}<p class="speaker-bio">{{ speaker.bio }}</p>{% endif %}
        </div>
      </div>
      {% if speaker.photos and speaker.photos.length > 0 %}
      <div class="speaker-photos">
        {% for photo in speaker.photos %}<img src="{{ photo }}" alt="{{ speaker.name }}">{% endfor %}
      </div>
      {% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}
  {% include "share.njk" %}
  <p class="event-back"><a href="/events/">← Back to Events</a></p>
</article>
