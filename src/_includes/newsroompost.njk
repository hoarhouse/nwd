---
layout: base.njk
---
<article class="np">
  <header class="np-header">
    <p class="np-kicker">Newsroom</p>
    {% if title %}<h1 class="np-title">{{ title }}</h1>{% endif %}
    {% if date %}<p class="np-meta"><time datetime="{{ date | isoDate }}">{{ date | dateDisplay }}</time></p>{% endif %}
  </header>
  {% if gallery %}
  <div class="gallery">
    {% for img in gallery %}
    <img class="gallery-item" src="{{ img }}" alt="">
    {% endfor %}
  </div>
  {% elif embed %}
  <div class="embed-wrap {% if orientation == 'vertical' %}embed-vertical{% else %}embed-landscape{% endif %}">
    {% if embed == "youtube" %}
    <iframe src="https://www.youtube-nocookie.com/embed/{{ embedId }}" title="{{ title or 'Embedded video' }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    {% elif embed == "vimeo" %}
    <iframe src="https://player.vimeo.com/video/{{ embedId }}" title="{{ title or 'Embedded video' }}" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
    {% endif %}
  </div>
  {% elif media %}
  <div class="media">
    {% if mediaType == "video" %}
    <video class="media-item" controls preload="metadata"{% if poster %} poster="{{ poster }}"{% endif %}>
      <source src="{{ media }}" type="video/mp4">
    </video>
    {% else %}
    <img class="media-item" src="{{ media }}" alt="{{ mediaAlt or title or '' }}">
    {% endif %}
  </div>
  {% endif %}
  <div class="np-body">
    {{ content | safe }}
  </div>
  {% include "share.njk" %}
  <p class="np-back"><a href="/newsroom/">← Back to Newsroom</a></p>
</article>
