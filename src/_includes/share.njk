<div class="post-share">
  <p class="post-share-label">Share this</p>
  <div class="post-share-row">
    <button class="psh-btn psh-primary psh-native" type="button" hidden>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/></svg>
      <span>Share</span>
    </button>
    <button class="psh-btn psh-copy" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.72"/><path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.72-1.72"/></svg>
      <span class="psh-copy-lbl">Copy link</span>
    </button>
    <a class="psh-btn psh-email" href="#" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
      <span class="lbl">Email</span>
    </a>
    <a class="psh-btn psh-li" href="#" target="_blank" rel="noopener" aria-label="Share on LinkedIn">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3-.02-2.97-1.8-2.97-1.82 0-2.1 1.4-2.1 2.87V21h-4z"/></svg>
      <span class="lbl">LinkedIn</span>
    </a>
    <a class="psh-btn psh-fb" href="#" target="_blank" rel="noopener" aria-label="Share on Facebook">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>
      <span class="lbl">Facebook</span>
    </a>
    <a class="psh-btn psh-x" href="#" target="_blank" rel="noopener" aria-label="Share on X">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.24 2H21.5l-7.5 8.57L23 22h-6.94l-5.43-7.1L4.4 22H1.13l8.02-9.17L1 2h7.12l4.9 6.48L18.24 2zm-1.22 18h1.8L7.05 3.9H5.12L17.02 20z"/></svg>
      <span class="lbl">X</span>
    </a>
  </div>
</div>
<script>
(function(){
  var share=document.querySelector('.post-share'); if(!share) return;
  var url=window.location.href;
  var h1=document.querySelector('h1');
  var title=(h1?h1.textContent:document.title).trim();
  var u=encodeURIComponent(url), t=encodeURIComponent(title);
  var native=share.querySelector('.psh-native');
  if(navigator.share){
    native.hidden=false;
    native.addEventListener('click',function(){ navigator.share({title:title,url:url}).catch(function(){}); });
  }
  var copy=share.querySelector('.psh-copy'), lbl=share.querySelector('.psh-copy-lbl');
  function done(){ copy.classList.add('psh-copied'); lbl.textContent='Copied!'; setTimeout(function(){ copy.classList.remove('psh-copied'); lbl.textContent='Copy link'; },1600); }
  function fallback(){ var ta=document.createElement('textarea'); ta.value=url; ta.setAttribute('readonly',''); ta.style.position='absolute'; ta.style.left='-9999px'; document.body.appendChild(ta); ta.select(); try{document.execCommand('copy');}catch(e){} document.body.removeChild(ta); done(); }
  copy.addEventListener('click',function(){
    if(navigator.clipboard && navigator.clipboard.writeText){ navigator.clipboard.writeText(url).then(done).catch(fallback); } else { fallback(); }
  });
  share.querySelector('.psh-email').href='mailto:?subject='+t+'&body='+t+'%0A%0A'+u;
  share.querySelector('.psh-li').href='https://www.linkedin.com/sharing/share-offsite/?url='+u;
  share.querySelector('.psh-fb').href='https://www.facebook.com/sharer/sharer.php?u='+u;
  share.querySelector('.psh-x').href='https://twitter.com/intent/tweet?url='+u+'&text='+t;
})();
</script>
