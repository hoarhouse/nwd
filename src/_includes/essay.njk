---
layout: base.njk
bodyClass: article
---
<article class="essay">
  <header class="essay-banner{% if not hero %} essay-banner-plain{% endif %}">
    {% if hero %}<div class="essay-banner-bg"><img src="{{ hero }}" alt="{{ title }}"></div>{% endif %}
    <div class="essay-banner-inner">
      {% if publication or category %}<p class="essay-kicker">{% if publication %}<span class="essay-publication">{{ publication }}</span>{% endif %}{% if category %}<span class="essay-category">{{ category }}</span>{% endif %}</p>{% endif %}
      <h1 class="essay-title">{{ title }}</h1>
      {% if summary %}<p class="essay-dek">{{ summary }}</p>{% endif %}
      {% if author %}
      <div class="essay-byline">
        {% if authorPhoto %}<img class="avatar" src="{{ authorPhoto }}" alt="{{ author }}">{% else %}<div class="avatar avatar-initials">{{ authorInitials }}</div>{% endif %}
        <div class="essay-byline-info">
          <span class="essay-author">{{ author }}</span>
          <span class="essay-byline-detail">{% if authorTitle %}{{ authorTitle }}{% endif %}{% if authorTitle and date %} · {% endif %}{% if date %}<time datetime="{{ date | isoDate }}">{{ date | dateDisplay }}</time>{% endif %}</span>
        </div>
      </div>
      {% endif %}
    </div>
  </header>
  <div class="essay-body">
    {{ content | safe }}
  </div>
  {% if tags %}
  <footer class="essay-tags">
    {% for tag in tags %}{% if tag != "essays" %}<span class="tag">{{ tag }}</span>{% endif %}{% endfor %}
  </footer>
  {% endif %}
  {% include "share.njk" %}
  <div class="essay-backlink"><a href="/writing/">← All writing</a></div>
</article>
