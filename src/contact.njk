---
layout: base.njk
title: Contact
summary: "Get in touch with the Domus Communis Foundation team."
bodyClass: article
---
<article class="contact">
  <header class="essay-banner essay-banner-plain ct-banner">
    <div class="essay-banner-inner">
      <p class="essay-kicker"><span class="essay-publication">Contact</span></p>
      <h1 class="essay-title">Get in touch</h1>
      <p class="essay-dek">Questions, partnership inquiries, or media requests — we'd love to hear from you.</p>
    </div>
  </header>

  <div class="ct-wrap">
    <div class="ct-grid">
      <form class="ct-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contact">
        <p class="ct-hp"><label>Don't fill this out if you're human: <input name="bot-field"></label></p>
        <label class="ct-field"><span>Name</span><input type="text" name="name" required></label>
        <label class="ct-field"><span>Email</span><input type="email" name="email" required></label>
        <label class="ct-field"><span>Subject</span>
          <span class="ct-select-wrap"><select name="subject">
            <option value="General Inquiry">General Inquiry</option>
            <option value="Partnership">Partnership</option>
            <option value="Donation">Donation</option>
            <option value="Media">Media</option>
            <option value="Other">Other</option>
          </select></span>
        </label>
        <label class="ct-field"><span>Message</span><textarea name="message" rows="6" required></textarea></label>
        <button class="ct-submit" type="submit">Send Message <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></button>
      </form>

      <aside class="ct-aside">
        <div class="ct-panel">
          <p class="ct-aside-label">Email</p>
          <a class="ct-email" href="mailto:alessio.pecorario@dcffoundation.org">alessio.pecorario@dcffoundation.org</a>
          <p class="ct-aside-note">Domus Communis Foundation is a registered 501(c)(3) non-profit organization. We aim to respond to all inquiries promptly.</p>
          <div class="ct-connect">
            <p class="ct-connect-label">Stay connected</p>
            <div class="ct-socials">
              <a href="{{ social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
              <a href="{{ social.linkedin }}" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3-.02-2.97-1.8-2.97-1.82 0-2.1 1.4-2.1 2.87V21h-4z"/></svg></a>
              <a href="{{ social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg></a>
              <a href="{{ social.x }}" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.24 2H21.5l-7.5 8.57L23 22h-6.94l-5.43-7.1L4.4 22H1.13l8.02-9.17L1 2h7.12l4.9 6.48L18.24 2z"/></svg></a>
              <a href="{{ social.youtube }}" target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.5c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor" stroke="none"/></svg></a>
              <a href="{{ social.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M16.6 5.82A4.28 4.28 0 0 1 15.54 3h-3.09v12.4a2.59 2.59 0 1 1-2.59-2.59c.27 0 .53.04.78.12V9.4a5.96 5.96 0 0 0-.78-.05 5.69 5.69 0 1 0 5.69 5.69V8.83a7.35 7.35 0 0 0 4.25 1.36V7.1a4.28 4.28 0 0 1-3.2-1.28z"/></svg></a>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</article>
