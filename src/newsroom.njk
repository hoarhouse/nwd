---
layout: base.njk
title: Newsroom
summary: Short updates and signals from the Domus Communis Foundation.
---
<div class="section-head">
  <h1>Newsroom</h1>
  <p class="section-dek">Short updates, signals, and notes from the Foundation.</p>
</div>
<div class="feed">
{% for post in collections.posts | reverse %}
  <article class="feed-post">
    <p class="feed-meta">
      {% if post.data.date %}<time datetime="{{ post.data.date | isoDate }}">{{ post.data.date | dateDisplay }}</time>{% endif %}
    </p>
    {% if post.data.title %}<h2 class="feed-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>{% endif %}
    {% if post.data.gallery %}
    <div class="gallery">
      {% for img in post.data.gallery %}
      <img class="gallery-item" src="{{ img }}" alt="">
      {% endfor %}
    </div>
    {% elif post.data.embed %}
    <div class="embed-wrap {% if post.data.orientation == 'vertical' %}embed-vertical{% else %}embed-landscape{% endif %}">
      {% if post.data.embed == "youtube" %}
      <iframe src="https://www.youtube-nocookie.com/embed/{{ post.data.embedId }}" title="{{ post.data.title or 'Embedded video' }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      {% elif post.data.embed == "vimeo" %}
      <iframe src="https://player.vimeo.com/video/{{ post.data.embedId }}" title="{{ post.data.title or 'Embedded video' }}" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
      {% endif %}
    </div>
    {% elif post.data.media %}
    <div class="media">
      {% if post.data.mediaType == "video" %}
      <video class="media-item" controls preload="metadata"{% if post.data.poster %} poster="{{ post.data.poster }}"{% endif %}>
        <source src="{{ post.data.media }}" type="video/mp4">
      </video>
      {% else %}
      <img class="media-item" src="{{ post.data.media }}" alt="{{ post.data.mediaAlt or post.data.title or '' }}">
      {% endif %}
    </div>
    {% endif %}
    <div class="feed-body">
      {{ post.templateContent | safe }}
    </div>
    <p class="feed-permalink"><a href="{{ post.url }}">Permalink</a></p>
  </article>
{% endfor %}
</div>