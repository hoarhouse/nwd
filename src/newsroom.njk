---
layout: base.njk
title: Newsroom
summary: Short updates and signals from the Domus Communis Foundation.
bodyClass: newsroom
---
<div class="section-head">
  <h1>Newsroom</h1>
  <p class="section-dek">Short updates, signals, and notes from the Foundation.</p>
</div>
<div class="nf-feed">
{% for post in collections.posts | reverse %}
  {% set hasThumb = post.data.gallery or (post.data.embed == 'youtube') or (post.data.media and post.data.mediaType != 'video') or (post.data.media and post.data.poster) %}
  <article class="nf-item{% if hasThumb %} nf-has-media{% endif %}">
    {% if hasThumb %}
    <a class="nf-media" href="{{ post.url }}">
      {% if post.data.gallery %}<img src="{{ post.data.gallery[0] }}" alt="">
      {% elif post.data.embed == 'youtube' %}<img src="https://img.youtube.com/vi/{{ post.data.embedId }}/hqdefault.jpg" alt="">
      {% elif post.data.media and post.data.mediaType != 'video' %}<img src="{{ post.data.media }}" alt="">
      {% elif post.data.poster %}<img src="{{ post.data.poster }}" alt="">
      {% endif %}
    </a>
    {% endif %}
    <div class="nf-text">
      {% if post.data.date %}<p class="nf-date"><time datetime="{{ post.data.date | isoDate }}">{{ post.data.date | dateDisplay }}</time></p>{% endif %}
      {% if post.data.title %}<h2 class="nf-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>{% endif %}
      <div class="nf-excerpt">{% if post.data.summary %}{{ post.data.summary }}{% else %}{{ post.templateContent | safe }}{% endif %}</div>
      <p class="nf-more"><a href="{{ post.url }}">Read more →</a></p>
    </div>
  </article>
{% endfor %}
</div>
